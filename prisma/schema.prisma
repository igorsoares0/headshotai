// Prisma 7 (driver-adapter / "Rust-free"). The `prisma-client` generator with an
// explicit output avoids the Turbopack ".prisma/client/default" resolution bug.
generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

// Prisma 7 moved connection URLs out of the schema and into prisma.config.ts.
// Runtime connection is supplied by the Neon driver adapter (see lib/prisma.ts).
datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(cuid())
  name          String?
  email         String    @unique
  passwordHash  String
  emailVerified DateTime? // null = email not confirmed; gates the paid action
  createdAt     DateTime  @default(now())
}

// Single-use, expiring token for email verification and password reset. Only the
// SHA-256 hash of the token is stored — the raw token lives solely in the emailed
// link, so a DB leak can't be replayed. A new token of the same type invalidates
// any prior unconsumed ones for that user.
model VerificationToken {
  id         String    @id @default(cuid())
  userId     String
  tokenHash  String    @unique
  type       String // "verify_email" | "reset_password"
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId, type])
}

// A generation order. The per-image `shots` array, plus `styles`/`referenceUrls`,
// are stored as JSON columns — they're always read/written together with the
// order, never queried individually (option a: JSON over a relational Shot table).
model Order {
  id             String   @id // app-generated "ord_…"
  userId         String
  createdAt      DateTime @default(now())
  status         String // training | generating | gating | ready | failed
  packId         String
  targetCount    Int
  subject        String? // prompt anchor, e.g. "Latino man" (reqs §12/§14)
  styles         Json
  trainingId     String
  destination    String
  trainedVersion String?
  referenceUrls  Json
  photoCount     Int
  trainSeconds   Float?
  genSeconds     Float    @default(0)
  shots          Json     @default("[]")
  error          String?

  @@index([userId])
}

// One-time Paddle purchase. A `completed`, unconsumed Purchase entitles the user
// to start exactly one generation order (consumed when the order is created).
model Purchase {
  id          String   @id @default(cuid())
  userId      String
  packId      String // starter | pro | premium
  photoCount  Int
  priceId     String
  status      String   @default("pending") // pending | completed | consumed
  paddleTxnId String?  @unique // Paddle transaction id — dedupes webhook replays
  orderId     String? // set when consumed by an order
  createdAt   DateTime @default(now())

  @@index([userId, status])
}
