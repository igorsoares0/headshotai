# Copy this file to .env.local (gitignored). Both the Next app AND the Prisma CLI
# read from .env.local — keep everything in that single file.

# Replicate API token — required. Get one at https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=r8_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Public base URL Replicate can POST webhooks to (no trailing slash).
# - Prod: your deploy origin, e.g. https://aperture.example.com
# - Local dev: a tunnel to localhost, e.g. cloudflared/ngrok URL
#       npx cloudflared tunnel --url http://localhost:3000
#   then set WEBHOOK_BASE_URL to the https URL it prints.
# When UNSET, orders advance via client polling instead of webhooks (fallback).
WEBHOOK_BASE_URL=

# --- Auth (Auth.js v5 + Neon Postgres via Prisma) ---
# Create a free project at https://neon.tech and copy BOTH connection strings:
#   DATABASE_URL = the POOLED string (host has "-pooler") — used by the app at runtime.
#   DIRECT_URL   = the UNPOOLED string (no "-pooler")     — used by `prisma migrate`.
DATABASE_URL="postgresql://user:pass@ep-xxxx-pooler.region.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://user:pass@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require"

# Session signing secret. Generate with: npx auth secret
AUTH_SECRET=replace_me

# After filling the above:
#   npx prisma migrate dev --name init   # creates the `users` table in Neon

# --- Billing (Paddle, one-time packs) ---
# Sandbox while developing. Create 3 one-time products/prices in the Paddle
# dashboard, then paste their price ids (pri_…) below.
NEXT_PUBLIC_PADDLE_ENV=sandbox
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=test_xxxxxxxxxxxxxxxxxxxxxxxx   # Paddle > Developer tools > Authentication (client-side token)
PADDLE_API_KEY=pdl_sdbx_apikey_xxxxxxxxxxxxxxxxxxxxxxxx           # server API key
PADDLE_WEBHOOK_SECRET=pdl_ntfset_xxxxxxxxxxxxxxxxxxxxxxxx         # Notifications > your webhook > secret key
PADDLE_PRICE_STARTER=pri_xxxxxxxxxxxxxxxxxxxxxxxx   # $25 / 30 photos
PADDLE_PRICE_PRO=pri_xxxxxxxxxxxxxxxxxxxxxxxx       # $40 / 50 photos
PADDLE_PRICE_PREMIUM=pri_xxxxxxxxxxxxxxxxxxxxxxxx   # $59 / 80 photos
# Point a Paddle webhook (Notifications) at: <public-tunnel>/api/webhooks/paddle
# subscribed to the `transaction.completed` event (use cloudflared like WEBHOOK_BASE_URL).
