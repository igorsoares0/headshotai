# Replicate API token — required. Get one at https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=r8_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Public base URL Replicate can POST webhooks to (no trailing slash).
# - Prod: your deploy origin, e.g. https://aperture.example.com
# - Local dev: a tunnel to localhost, e.g. cloudflared/ngrok URL
#       npx cloudflared tunnel --url http://localhost:3000
#   then set WEBHOOK_BASE_URL to the https URL it prints.
# When UNSET, orders advance via client polling instead of webhooks (fallback).
WEBHOOK_BASE_URL=
